#source: "https://pkg.go.dev/github.com/gokcehan/lf"

source ~/.config/lf/cmds.sh

# Sets
set shell bash
set hidden true
set icons true

set previewer ./extras/preview.sh
set cleaner ./extras/clean.sh

set ignorecase true
set incsearch true

set mouse true # allow mouse input
set scrolloff 8


# Maps
##view/open the current file
map <enter> open
map l open
map e edit

##execute current file
map x $$f
map X !$f

##trash file
#map D trash "$f"
#map dd rm "$f"

##semicolon to enter cmds
#map ";" push ":"
#map ":" push ";"

##scroll up/down
map K scrollup
map J scrolldown

##mouse input
map <m-up> scrollup
map <m-down> scrolldown

## Shortcuts
map gh cd ~/

map gp cd ~/proj/
map gr cd ~/proj/repos/

map gi cd ~/media/pics/
map gv cd ~/media/vids/
map ga cd ~/media/audio/

map gf cd ~/files/
map gt cd ~/tmp/
map gd cd ~/tmp/downloads/

