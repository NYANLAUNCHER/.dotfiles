#source: "https://pkg.go.dev/github.com/gokcehan/lf"

# Sources
source cmds.sh


# Sets
set shell bash
set hidden true
set icons true

set previewer ~/.config/lf/extras/preview.sh
set cleaner ~/.config/lf/extras/clean.sh

set ignorecase true
set incsearch true

set mouse true # allow mouse input
set scrolloff 8


# Maps
##view/open the current file
map <enter> :open
map v :view

##execute current file
map x $$f
map X !$f

##semicolon to enter cmds
map ";" ":"

##scroll up/down
map K scrollup
map J scrolldown

##mouse input
map <m-up> up
map <m-down> down

## Shortcuts
map gh
map ~ cd ~/

map gp cd ~/proj/
map gr cd ~/proj/repos/

map gi cd ~/media/pics/
map gv cd ~/media/vids/
map ga cd ~/media/audio/

map gf cd ~/files/
map gt cd ~/tmp/
map gd cd ~/tmp/downloads

