#!/bin/sh
# nmcli wrapper script

connect () {
    read -p "Enter wifi device: " wifi_device
    echo -n "Enter password: "
    while IFS=$'\n' read -r -s -n1 pass; do
    if [[ -z $pass ]]; then
        echo
        break
    else
        echo -n '*'
        wifi_password+=$pass
    fi
    done
    nmcli device wifi connect "$wifi_device" password "$wifi_password"
}

list () {
    nmcli device wifi list
}

help () {
echo -e "Commands:
    \"connect <args>\", Connect to wifi networks.
      <args> = 
          \"\" = List networks before showing prompt.
          \"-np\" = No prompt.
          \"-nl\" = Don't list wifi networks.

    \"list\", Show wifi networks.

    \"help\", List this helpful text."
}

case $1 in
    "connect") case $2 in
        #list networks before showing prompt
        "") list; connect ;;

        #no prompt
        "-np") nmcli device wifi connect "$3" password "$4" ;;

        #don't list wifi networks
        "-nl") connect ;;
        *) echo -e "That is not a supported command.\nTry, \"ez-nmcli help\"."
    esac ;;
    "list") list ;;
    "help") help ;;
    *) echo -e "That is not a supported command.\nTry, \"ez-nmcli help\"."
esac
