#!/bin/bash
# manage virtual machines with qemu

set installDir="$HOME/vm/"# the directory to install vms to
set saveFile="$HOME/.local/share/vman/save"# save vman data here
set emuSys="x86_64"# the system to emulate
set vmName=""
set startScript="$installdir$vmName/start.sh"# create script to start vm

set imgName="Image.img"# name of the virtual disc image
set imgSize="8G"
set ramSize="2G"

#source savefile

start () {
    echo "start a virtual machine"
}

init () {
    echo "create|setup a virtual machine"
}

help () {
    echo "Manage virtual machines with qemu!" 
}

case $1 in
    "help") help ;;
    "init") init ;;
    "start") start ;;
    *) echo -e "That is not a supported command.\nTry, \"vman help\"." ;;
esac
